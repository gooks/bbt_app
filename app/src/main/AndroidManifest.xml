<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".BusApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BusApp"
        android:usesCleartextTraffic="true">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BusApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 위젯 설정 화면: exported="true" 및 CONFIGURE 액션 필수 -->
        <!-- 위젯 설정 화면 -->
        <activity android:name=".widget.BusAlertWidgetConfigActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- 삼성 루틴 설정 화면: 루틴 앱의 '동작' 리스트에 앱이 뜨게 함 -->
        <activity android:name=".receiver.BusAlertRoutineConfigActivity"
            android:label="알림 시작하기"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.CREATE_SHORTCUT" />
                <action android:name="com.samsung.android.app.routines.CREATE_ROUTINE_ACTION" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.BusAlertService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- 위젯 등록 -->
        <receiver
            android:name=".widget.BusAlertWidget"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.czt.bbt.ACTION_WIDGET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- 삼성 루틴 연동을 위한 전용 리시버 (exported="true" 필수) -->
        <receiver
            android:name=".receiver.BusAlertReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.czt.bbt.START_RIDE" />
                <action android:name="com.czt.bbt.START_ARRIVAL" />
                <action android:name="com.czt.bbt.STOP_ALERT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
